# Скопируйте файл в .env. Реальные ключи и токены никогда не коммитьте.
# Process environment имеет приоритет над значениями из .env.

# Токен Telegram-бота от @BotFather.
TELEGRAM_TOKEN=
# Числовые Telegram user ID владельцев через запятую. Бот работает только в ЛС.
ADMIN_TELEGRAM_IDS=

# Bybit API key/secret: только Read + Contract Trading, без права вывода.
BYBIT_API_KEY=
BYBIT_API_SECRET=
# Официальный контур: mainnet, testnet или demo.
BYBIT_ENV=testnet
# Допустимое окно времени подписи, мс.
BYBIT_RECV_WINDOW_MS=5000
# Таймаут одного HTTP-запроса Bybit, секунд.
BYBIT_HTTP_TIMEOUT_SECONDS=15
# dry блокирует все изменяющие запросы; live отправляет реальные ордера.
TRADING_MODE=dry
# Для live обязательно точное осознанное подтверждение:
LIVE_TRADING_CONFIRMATION=
# Пример значения: I_ACCEPT_LIVE_TRADING_RISK

# Ключ DeepSeek. В модель уходит только минимальный whitelist snapshot.
DEEPSEEK_API_KEY=
# OpenAI-compatible endpoint и актуальный ID модели.
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# Таймаут одной AI-попытки и жёсткий лимит JSON-ответа.
# Разрешён один retry; обе попытки должны укладываться в TTL сигнала ниже.
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_MAX_TOKENS=2048
# Логи AI выключены по умолчанию; при включении хранятся без raw wallet context.
DEEPSEEK_LOG_RESPONSES=false
DEEPSEEK_LOG_RETENTION_DAYS=7

# Разрешённые USDT-linear активы через запятую, максимум 12.
TRADABLE_TOKENS=BTC,ETH,SOL,XRP,BNB,DOGE
# Пауза между автоматическими циклами, секунд; минимум 30.
POLL_INTERVAL=180

# Максимальный риск до SL одной сделки и всего портфеля, % equity.
MAX_RISK_PER_TRADE_PERCENT=1
MAX_TOTAL_RISK_PERCENT=5
# Дневной блок: realized loss и drawdown equity от UTC high-water, %.
MAX_DAILY_LOSS_PERCENT=3
# Максимальный номинал одной позиции, % equity.
MAX_POSITION_NOTIONAL_PERCENT=100
# Общий hard cap плеча и максимум, используемый авто-режимом.
MAX_LEVERAGE=5
AUTO_LEVERAGE=2
# Дополнительный локальный минимум ордера; live минимум Bybit читается динамически.
MIN_ORDER_SIZE_USDT=10
# Минимальный net R/R уже после fee, spread и допустимого проскальзывания.
MIN_NET_RISK_REWARD_RATIO=1.5

# Execution gates: максимальный spread и уход цены от snapshot, %.
MAX_SPREAD_PERCENT=0.15
MAX_PRICE_DRIFT_PERCENT=0.25
# Оценка exit-slippage и жёсткий cap цены входа, %.
ESTIMATED_SLIPPAGE_PERCENT=0.05
BYBIT_MAX_SLIPPAGE_PERCENT=0.30
# Запасная taker fee как доля: 0.0006 = 0.06%.
FALLBACK_TAKER_FEE_RATE=0.0006
# Срок жизни AI-решения, секунд.
SIGNAL_VALIDITY_SECONDS=90
# Минимальное изменение SL перед повторным update, %.
TP_SL_MIN_CHANGE_PERCENT=0.05

# Необязательный абсолютный путь к SQLite. По умолчанию: data/crypto_bot.sqlite3.
# CRYPTO_DB_PATH=D:\path\to\crypto_bot.sqlite3
